# ============================================================
# BotCore AI — Backend Environment Variables
# Copy this to .env and fill in real values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/botcore

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# --- Telegram (optional at start — configure from Admin UI) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://your-backend.railway.app/api/telegram/webhook

# --- Phase 5: Celery / Automation ---
# Redis is already set above — Celery uses the same REDIS_URL for broker + backend
# To run the worker locally: celery -A tasks.celery_app.celery_app worker --beat --loglevel=info

# --- Phase 6: Multichannel ---
# WhatsApp (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=botcore_wh_verify

# Facebook Messenger
FACEBOOK_PAGE_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_VERIFY_TOKEN=botcore_fb_verify
FACEBOOK_APP_SECRET=

# Instagram (via Facebook Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# --- Phase 4: Multimodal ---
# Voice transcription: "groq" (default, free) | "openai" | "local"
WHISPER_PROVIDER=groq
WHISPER_MODEL=whisper-large-v3
# Image OCR: "tesseract" (default, free) | "google"
IMAGE_PROVIDER=tesseract
GOOGLE_VISION_API_KEY=
# Max upload size in bytes (default 20 MB)
MAX_UPLOAD_BYTES=20971520

# --- Environment ---
ENVIRONMENT=production
LOG_LEVEL=INFO

# ============================================================
# Railway will inject DATABASE_URL and REDIS_URL automatically
# when you add PostgreSQL and Redis plugins to your project.
# ============================================================
